deo-5-1-0" value="课堂随录的，比平时唠叨些，需要的朋友自取&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7271452082337598760"><mxGeometry x="1160" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-86" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-1" target="video-5-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-1-1" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="1160" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-87" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-1" target="video-5-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-2" value="&lt;b&gt;发接发目的性&lt;/b&gt;&lt;br&gt;32 条 · 关键词：目的性、抓球、主动、限制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-88" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-2-0" value="体系认知1 希望大家一定要看完，会非常有收获&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7600107130034047973"><mxGeometry x="1160" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-89" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-2" target="video-5-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-2-1" value="被动高远 别说这样容易抡大臂，不这样偷出来时间抢架拍位置也是个输，真被动就没时间侧身，没时间架拍，没空间做…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7558912953539071292"><mxGeometry x="1160" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-90" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-2" target="video-5-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-6" value="&lt;b&gt;训练与纠错&lt;/b&gt;&lt;br&gt;149 条 · 训练设计、常见错误、实战复盘和恢复对抗能力。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1E4E8;strokeColor=#9A5968;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-91" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-0" value="&lt;b&gt;训练方法&lt;/b&gt;&lt;br&gt;51 条 · 关键词：训练、练习、多球、三步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-92" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-0-0" value="如何快速恢复对抗能力 觉得训练的时候实在不行了，就可以直接最后一个项目了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 13&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7432633273060314408"><mxGeometry x="1930" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-93" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-0" target="video-6-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-0-1" value="1 白鞋白胶布2低重心步法回动3低重心步法训练，这是我自创训练&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7085169366005714217"><mxGeometry x="1930" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-94" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-0" target="video-6-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-1" value="&lt;b&gt;常见错误纠正&lt;/b&gt;&lt;br&gt;97 条 · 关键词：错误、不对、纠正、问题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-95" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-1-0" value="日常纠错抡大臂 没有演，一箱球都打完了，问题还有但是时间有限，不过t老师已经得救了算是&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7397746202562956559"><mxGeometry x="1930" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-96" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-1" target="video-6-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-1-1" value="爆改球友 转髋还有问题，不过可以先熟悉动作了，其他的问题可以有了转髋后再微调&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7492357671853526329"><mxGeometry x="1930" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-97" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-1" target="video-6-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-2" value="&lt;b&gt;实战复盘&lt;/b&gt;&lt;br&gt;30 条 · 关键词：实战、战术、复盘、比赛" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-98" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-2-0" value="各位想在天上飞，得先学会交叉步贴地飞哦😂&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7083684012513840424"><mxGeometry x="1930" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-99" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-2" target="video-6-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-2-1" value="今天本来想拍教学的，但是人手不够😂，内涵一下某地区比赛，大家知道是哪里嘛？&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 5&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7094072057608047913"><mxGeometry x="1930" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-100" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-2" target="video-6-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-3" value="&lt;b&gt;恢复与体能&lt;/b&gt;&lt;br&gt;7 条 · 关键词：恢复、体能、对抗能力、精疲力尽" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1990" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-101" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-3-0" value="如何快速恢复对抗能力 觉得训练的时候实在不行了，就可以直接最后一个项目了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 13&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7432633273060314408"><mxGeometry x="1930" y="1986" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-102" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-3" target="video-6-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-3-1" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="1930" y="2064" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-103" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-3" target="video-6-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-7" value="&lt;b&gt;握拍与基本动作&lt;/b&gt;&lt;br&gt;122 条 · 握拍、基础挥拍、基础动作和拍面控制。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4EDF0;strokeColor=#51727B;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="2370" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-104" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-7-0" value="&lt;b&gt;握拍&lt;/b&gt;&lt;br&gt;38 条 · 关键词：握拍、正手握拍、反手握拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-105" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-7" target="subtopic-7-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-0-0" value="半拳式握拍是发力必备的握拍，没有半拳式，基本出现不了鞭甩，因为大拇指会卡住&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 17&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7086276287681137961"><mxGeometry x="2700" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-106" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-0" target="video-7-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-0-1" value="大家除了这两集，还可以结合我置顶的第一个作品看&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7086648517627858176"><mxGeometry x="2700" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-107" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-0" target="video-7-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-7-1" value="&lt;b&gt;基础挥拍&lt;/b&gt;&lt;br&gt;35 条 · 关键词：基础挥拍、挥拍、随摆" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-108" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-7" target="subtopic-7-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-1-0" value="基础挥拍重快 由于要控制时长我剪辑的很精简，基础挥拍如何打的重，如何打的快，建议多看两边，详细的我们直播间…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 16&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7383154379915906319"><mxGeometry x="2700" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-109" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-1" target="video-7-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-1-1" value="兄弟们，学不会起跳的，咱们先来个引导版吧，自己打个几次就会正式的了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7161980324409363712"><mxGeometry x="2700" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-110" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-1" target="video-7-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-7-2" value="&lt;b&gt;拍面控制&lt;/b&gt;&lt;br&gt;78 条 · 关键词：拍面、角度、控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-111" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-7" target="subtopic-7-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-2-0" value="这个实战很行，击球点在额头前或上一个头的位置&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7064372942880148777"><mxGeometry x="2700" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-112" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-2" target="video-7-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-2-1" value="正反手过渡 先掌握核心技术，剩下的靠自己也是不错的方法&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7515625891511995706"><mxGeometry x="2700" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-113" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-2" target="video-7-2-1"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>