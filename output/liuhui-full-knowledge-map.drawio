pacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7078852452442836224"><mxGeometry x="1160" y="2151" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-101" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-4" target="video-5-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-4-1" value="方法一把球放到侧面，方法二改变握拍&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7111887264187190528"><mxGeometry x="1160" y="2229" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-102" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-4" target="video-5-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-6" value="&lt;b&gt;发球与接发&lt;/b&gt;&lt;br&gt;20 条 · 单双打发球、接发、变化和发接发目的性。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1E4E8;strokeColor=#9A5968;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-103" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-0" value="&lt;b&gt;发小球&lt;/b&gt;&lt;br&gt;5 条 · 关键词：发小球、反手发球、正手发球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-104" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-0-0" value="正手发小球的教学，以前的作品里有，没有好的发球，只有合适的发球&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7254755365995285812"><mxGeometry x="1930" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-105" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-0" target="video-6-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-0-1" value="发小球进阶 大家总是关注球飞的贴不贴，贴当然重要，但是力量控制到过网能落也很重要&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589590613499595185"><mxGeometry x="1930" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-106" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-0" target="video-6-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-1" value="&lt;b&gt;发后场与发球变化&lt;/b&gt;&lt;br&gt;11 条 · 关键词：发高远、发后场、偷后场、发球变化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-107" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-1-0" value="发球变化 发球隐蔽是非常重要的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7483346020332522812"><mxGeometry x="1930" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-108" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-1" target="video-6-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-1-1" value="反手发后场 现在的规则是不超过1.15高度就可以，其实不用太在乎球拍在哪结束&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7508222669708463420"><mxGeometry x="1930" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-109" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-1" target="video-6-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-2" value="&lt;b&gt;接发与抢发&lt;/b&gt;&lt;br&gt;3 条 · 关键词：接发、接发球、抢发、抓发球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-110" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-2-0" value="课堂随录的，比平时唠叨些，需要的朋友自取&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7271452082337598760"><mxGeometry x="1930" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-111" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-2" target="video-6-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-2-1" value="接发准备 每个人都要清楚做动作的目的性，不能盲目学习&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7639306481355832689"><mxGeometry x="1930" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-112" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-2" target="video-6-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-3" value="&lt;b&gt;发接发目的性&lt;/b&gt;&lt;br&gt;2 条 · 关键词：发接发、抓球、发球目的、接发目的" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1990" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-113" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalL