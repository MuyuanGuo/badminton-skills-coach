<mxfile host="app.diagrams.net" modified="2026-07-10T00:00:00.000Z" agent="Codex" version="24.7.17"><diagram id="liuhui-full" name="全量教学知识图谱"><mxGraphModel dx="2400" dy="2600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="2600" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="skill" value="刘辉羽毛球 Skill&lt;br&gt;&lt;b&gt;350 条教学证据&lt;/b&gt;&lt;br&gt;8 个主题大类 · 342 条已入主题索引" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#123B36;fontColor=#FFFFFF;strokeColor=#0C2B27;strokeWidth=3;fontSize=18;fontStyle=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1360" y="80" width="440" height="120" as="geometry" /></mxCell><mxCell id="category-0" value="&lt;b&gt;后场技术&lt;/b&gt;&lt;br&gt;216 条 · 后场击球、被动处理、杀吊突击与架拍框架。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEFEA;strokeColor=#176B5B;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-0" value="&lt;b&gt;被动后场与高远&lt;/b&gt;&lt;br&gt;74 条 · 关键词：被动、高远、后高点、底线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-0-0" value="反手被动高远 虽然被动，但是放松发力更重要，别说示范的球不到位，也打出界一米了，主要是在底线摄像机放不下了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 45&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7546109410041908538"><mxGeometry x="390" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-0" target="video-0-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-0-1" value="被动高远 别说这样容易抡大臂，不这样偷出来时间抢架拍位置也是个输，真被动就没时间侧身，没时间架拍，没空间做…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 35&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7558912953539071292"><mxGeometry x="390" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-0" target="video-0-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-1" value="&lt;b&gt;杀球、突击与压球&lt;/b&gt;&lt;br&gt;73 条 · 关键词：杀球、突击、压球、重杀" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-1-0" value="杀球瞄准 杀球瞄准 卢迦彧的杀球不是那种很重的，所以落点上就尤为重要，比赛中非常容易被防守反击!中间涉及到…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 55&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7659348110628345210"><mxGeometry x="390" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-1" target="video-0-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-1-1" value="不同杀球 给大家解释为什么每个运动员动作不一样，其实在我的视角里，都是脚蹬地开始发力传递到球拍，但是每个人…&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567155406117533051"><mxGeometry x="390" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-1" target="video-0-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-2" value="&lt;b&gt;架拍与框架&lt;/b&gt;&lt;br&gt;62 条 · 关键词：架拍、框架、抬拍、举拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-2-0" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 58&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="390" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-2" target="video-0-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-2-1" value="快速架拍和力量架拍 在两者中间的架拍就是标准的普通架拍，既不会太慢，也不会没力，但是又都做不到极致的快和重…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 38&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7551459420703837498"><mxGeometry x="390" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-2" target="video-0-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-3" value="&lt;b&gt;吊球与劈吊&lt;/b&gt;&lt;br&gt;18 条 · 关键词：吊球、劈吊、滑板、假动作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-3-0" value="华云纵 入门是实用假动作，熟练后可以发展成花活，去参加职业比赛的朋友不用看后面的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7427416335900020008"><mxGeometry x="390" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-3" target="video-0-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-3-1" value="假动作可以不用，但是不能不会哦，要不拿什么耍帅😂，喜欢的留言直播间带走&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7061422431386324264"><mxGeometry x="390" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-3" target="video-0-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-4" value="&lt;b&gt;反手后场&lt;/b&gt;&lt;br&gt;75 条 · 关键词：反手、反拍、反手高远" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-14" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-4-0" value="反手动作不唯一，但是这种好上手，击球点在转过去的身前外侧&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 32&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7060717442825309480"><mxGeometry x="390" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-4" target="video-0-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-4-1" value="反手高远 这个大臂啊，用的越精炼越好，越多越完蛋&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 24&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7535400692573211962"><mxGeometry x="390" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-16" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-4" target="video-0-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-1" value="&lt;b&gt;步法与移动&lt;/b&gt;&lt;br&gt;92 条 · 启动、移动、回动、低重心和不同区域步法。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7E6DE;strokeColor=#B85C38;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="830" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-17" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-0" value="&lt;b&gt;启动与预动&lt;/b&gt;&lt;br&gt;28 条 · 关键词：启动、预动、起动、蹬地" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-18" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-0-0" value="分解步法种类繁多，这是练启动有代表性的，一轮一口气做完，做3组。我肯定是没做到10秒钟，要不视频太长😓&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 16&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7056244399390412064"><mxGeometry x="1160" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-19" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-0" target="video-1-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-0-1" value="腿蹬地，指发力&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7172742523096517927"><mxGeometry x="1160" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-20" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-0" target="video-1-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-1" value="&lt;b&gt;回动与连贯&lt;/b&gt;&lt;br&gt;26 条 · 关键词：回动、连贯、衔接、下一拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-21" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-1-0" value="这属于为了下一拍更好衔接的步法，也是使用率最高的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7229889111706848544"><mxGeometry x="1160" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-22" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-1" target="video-1-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-1-1" value="并不是说一定要一步回位。而是体现向左回动，左脚的重要性&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7059589039694957864"><mxGeometry x="1160" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-1" target="video-1-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-2" value="&lt;b&gt;交叉步与并步&lt;/b&gt;&lt;br&gt;25 条 · 关键词：交叉步、并步、垫步、步伐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-24" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-2-0" value="回动步法合理性 每个人的合理也不一样，有的人腿的力量强，并步能并很远，所以还要结合自己的情况&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7643719807951615482"><mxGeometry x="1160" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-2" target="video-1-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-2-1" value="发个老库存，垫步和并步都接双脚起跳的合适步法&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7064753436809514281"><mxGeometry x="1160" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-26" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-2" target="video-1-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-3" value="&lt;b&gt;低重心与被动救球&lt;/b&gt;&lt;br&gt;43 条 · 关键词：低重心、被动步法、救球、重心" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-27" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-3-0" value="1 白鞋白胶布2低重心步法回动3低重心步法训练，这是我自创训练&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 55&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7085169366005714217"><mxGeometry x="1160" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-28" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-3" target="video-1-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-3-1" value="就像跑步重心要在前面，倒退跑重心要在后面一样&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 17&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7185360811248864544"><mxGeometry x="1160" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-29" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-3" target="video-1-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-4" value="&lt;b&gt;正手区与网前步法&lt;/b&gt;&lt;br&gt;19 条 · 关键词：正手区、网前步法、上网、前后步法" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-30" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-4-0" value="正手区前后步法（基础版） 正手区前后步法种类非常多，这是一种比较简单合理的步法，而且教学对象是左手，左右手…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 36&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567860375287303035"><mxGeometry x="1160" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-31" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-4" target="video-1-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-4-1" value="正手网前步法 当然还要注意左手的摆放和重心的控制，但是时间有限，直播的时候讲吧&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7406541084219821312"><mxGeometry x="1160" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-32" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-4" target="video-1-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-2" value="&lt;b&gt;发力与身体运用&lt;/b&gt;&lt;br&gt;237 条 · 放松发力、旋转传导、腰腹、手腕与击球发力区间。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7EDF5;strokeColor=#456A8A;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-33" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-0" value="&lt;b&gt;放松与爆发&lt;/b&gt;&lt;br&gt;136 条 · 关键词：放松、爆发、发力、打透" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-34" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-0-0" value="放松架拍 没有说对错，是很多人还不会自然传动力量就开始锁定身体，锁住力量是为了让会发力的人爆发力最大化，不…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 48&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7628342769941691121"><mxGeometry x="1930" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-35" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-0" target="video-2-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-0-1" value="手指是末梢的发力，前面还需要很多带动，食指拇指都需要发力，只不过是支撑&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 28&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7097047150479084835"><mxGeometry x="1930" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-36" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-0" target="video-2-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-1" value="&lt;b&gt;腰腹与身体旋转&lt;/b&gt;&lt;br&gt;91 条 · 关键词：腰腹、核心、旋转、转体" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-37" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-1-0" value="腰腹发力 手放好位置，感受腰腹发力的方向，只有把方向做对，击球才能有效果&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 25&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7494729488699559225"><mxGeometry x="1930" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-38" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-1" target="video-2-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-1-1" value="一定要3集看完再去练啊😂霸王杀就是尽可能的让动作最高效，爆发力最大化，出手快动作小，易衔接，重心摇摆小等特…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 20&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7067722128413543680"><mxGeometry x="1930" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-39" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-1" target="video-2-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-2" value="&lt;b&gt;手腕、内旋与拍面&lt;/b&gt;&lt;br&gt;118 条 · 关键词：手腕、内旋、拍面、握拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-40" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-2-0" value="握拍从准备握拍，向右旋转直至虎口对着正拍面，或接近正拍面&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 41&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7146762792438074665"><mxGeometry x="1930" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-41" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-2" target="video-2-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-2-1" value="半拳式握拍是发力必备的握拍，没有半拳式，基本出现不了鞭甩，因为大拇指会卡住&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 23&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7086276287681137961"><mxGeometry x="1930" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-42" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-2" target="video-2-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-3" value="&lt;b&gt;贴球发力&lt;/b&gt;&lt;br&gt;8 条 · 关键词：贴球、贴近、发力空间" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-43" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-3-0" value="压球新讲 就算追求贴球发力，也得是建立在能把动作做完的基础上贴，怕打不到球也会本能的把球拍接近球而失去发力…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7440406891664133428"><mxGeometry x="1930" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-44" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-3" target="video-2-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-3-1" value="兄弟们也可以看往期的手指发力，贴球发力来做铺垫&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7145708380047297833"><mxGeometry x="1930" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-3" target="video-2-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-4" value="&lt;b&gt;挥拍路径&lt;/b&gt;&lt;br&gt;82 条 · 关键词：挥拍、随挥、半程、全程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-46" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-4-0" value="基础挥拍重快 由于要控制时长我剪辑的很精简，基础挥拍如何打的重，如何打的快，建议多看两边，详细的我们直播间…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 27&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7383154379915906319"><mxGeometry x="1930" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-47" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-4" target="video-2-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-4-1" value="一切的根源都是大臂走的太多失去了甩小臂的目的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 23&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7170144521781562662"><mxGeometry x="1930" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-48" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-4" target="video-2-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-3" value="&lt;b&gt;中前场与抽挡&lt;/b&gt;&lt;br&gt;105 条 · 抽挡、接杀、防守、网前技术和中前场转换。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBCF;strokeColor=#967326;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="2370" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-49" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-0" value="&lt;b&gt;平抽挡与高速对抗&lt;/b&gt;&lt;br&gt;6 条 · 关键词：抽挡、平抽挡、高速对抗、快球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-50" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-0-0" value="高速对抗步法 小姐姐是两省冠军🏆，这种情况属于高速对抗状态下，就是球都比较平，没有侧身的时间和意义&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 16&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7652440366436945017"><mxGeometry x="2700" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-51" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-0" target="video-3-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-0-1" value="握拍微调 抽挡反手为主，尽量不做正反手转换&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7447084061371272507"><mxGeometry x="2700" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-52" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-0" target="video-3-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-1" value="&lt;b&gt;接杀与防守&lt;/b&gt;&lt;br&gt;38 条 · 关键词：接杀、防守、防反、挡杀" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-53" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-1-0" value="双打防守思路 你总会遇到你挑不起来的进攻&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7621243051541587889"><mxGeometry x="2700" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-54" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-1" target="video-3-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-1-1" value="单打防守 主要在于省步子，和好衔接，当对方球速非常快的时候就只能这样接了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7586613438625959217"><mxGeometry x="2700" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-55" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-1" target="video-3-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-2" value="&lt;b&gt;网前搓勾扑&lt;/b&gt;&lt;br&gt;47 条 · 关键词：网前、搓球、勾球、扑球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-56" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-2-0" value="滚网搓球 双打网前有人看守时有奇效&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 31&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7509355373729762619"><mxGeometry x="2700" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-57" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-2" target="video-3-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-2-1" value="身前位勾球，和侧身位的勾球不一样，正手也存在变拍，只不过没反手那么需要&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 25&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7064010057020673314"><mxGeometry x="2700" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-58" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-2" target="video-3-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-3" value="&lt;b&gt;挡网与放网&lt;/b&gt;&lt;br&gt;14 条 · 关键词：挡网、放网、网前球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-59" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-3-0" value="挡网 我最近发的东西都是大家认为简单，但是一点不简单的东西&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7524557392328461627"><mxGeometry x="2700" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-60" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-3" target="video-3-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-3-1" value="中腰球出来，出现轮转的可能性很大&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7106697344128748835"><mxGeometry x="2700" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-61" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-3" target="video-3-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-4" value="&lt;b&gt;中前场衔接&lt;/b&gt;&lt;br&gt;16 条 · 关键词：中前场、衔接、连贯、封网" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-62" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-4-0" value="一个小小的方向改变就可以让进攻衔接的更加流畅&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7278130800220998946"><mxGeometry x="2700" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-63" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-4" target="video-3-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-4-1" value="压迫位封网 祝大家新年快乐！大年初二也不要忘记研究羽毛球啊！&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7607852875611759802"><mxGeometry x="2700" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-64" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-4" target="video-3-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-4" value="&lt;b&gt;双打战术&lt;/b&gt;&lt;br&gt;56 条 · 双打轮转、防守站位、封网、进攻组织和发接发配合。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9E3F2;strokeColor=#72578C;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-65" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-0" value="&lt;b&gt;双打发接发&lt;/b&gt;&lt;br&gt;6 条 · 关键词：双打发接发、接发、发接发、抓球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-66" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-0-0" value="双打发接发 永远考虑对手出球最快的位置，慢的位置球真来了再说&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 27&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7501542236061420859"><mxGeometry x="390" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-67" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-0" target="video-4-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-0-1" value="接发准备 每个人都要清楚做动作的目的性，不能盲目学习&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7639306481355832689"><mxGeometry x="390" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-68" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-0" target="video-4-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-1" value="&lt;b&gt;轮转与补位&lt;/b&gt;&lt;br&gt;12 条 · 关键词：轮转、补位、前后、左右" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-69" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-1-0" value="正手区前后步法（基础版） 正手区前后步法种类非常多，这是一种比较简单合理的步法，而且教学对象是左手，左右手…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 24&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567860375287303035"><mxGeometry x="390" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-70" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-1" target="video-4-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-1-1" value="双打实战轮转 无论训练时有多么默契，实战中都会有配合失误，那实战看的就是两个人的容错够不够&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7614167503938610417"><mxGeometry x="390" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-71" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-1" target="video-4-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-2" value="&lt;b&gt;双打防守站位&lt;/b&gt;&lt;br&gt;6 条 · 关键词：双打防守、防守站位、平行、护边" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-72" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-2-0" value="双打防守思路 你总会遇到你挑不起来的进攻&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7621243051541587889"><mxGeometry x="390" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-73" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-2" target="video-4-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-2-1" value="双打防守进阶 外旋是大臂带动小臂的必然动作，用手指发力也可以，但是非常考验力量&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7414339897990843663"><mxGeometry x="390" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-74" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-2" target="video-4-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-3" value="&lt;b&gt;封网与抢网&lt;/b&gt;&lt;br&gt;9 条 · 关键词：封网、抢网、前场" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1990" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-75" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-3-0" value="摇摆球对付抢网凶狠的对手，如果对方不抢网就没什么用啦😂&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7095554075210550528"><mxGeometry x="390" y="1986" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-76" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-3" target="video-4-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-3-1" value="压迫位封网 祝大家新年快乐！大年初二也不要忘记研究羽毛球啊！&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7607852875611759802"><mxGeometry x="390" y="2064" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-77" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-3" target="video-4-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-4" value="&lt;b&gt;进攻组织&lt;/b&gt;&lt;br&gt;32 条 · 关键词：进攻、组织、压制、后杀前封" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="2155" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-78" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-4-0" value="一个小小的方向改变就可以让进攻衔接的更加流畅&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7278130800220998946"><mxGeometry x="390" y="2151" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-79" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-4" target="video-4-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-4-1" value="双打进攻思路 抛砖引玉，场景太多，整体就是要根据自己和队友的位置去考虑&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 13&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7619576226616745445"><mxGeometry x="390" y="2229" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-80" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-4" target="video-4-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-5" value="&lt;b&gt;发球与接发&lt;/b&gt;&lt;br&gt;60 条 · 单打与双打发球、接发、发接发目的性。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2ECE4;strokeColor=#4F7A43;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="830" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-81" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-0" value="&lt;b&gt;发球&lt;/b&gt;&lt;br&gt;32 条 · 关键词：发球、发小球、偷后场" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-82" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-0-0" value="正手发小球的教学，以前的作品里有，没有好的发球，只有合适的发球&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 29&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7254755365995285812"><mxGeometry x="1160" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-83" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-0" target="video-5-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-0-1" value="保姆级反手发球教学 首先就是这三位都是年训学员，天天在一起关系比较好，所以说话自由一点，大家不要喷我！再一…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 19&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7626127268884067249"><mxGeometry x="1160" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-84" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-0" target="video-5-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-1" value="&lt;b&gt;接发&lt;/b&gt;&lt;br&gt;5 条 · 关键词：接发、接发球、抢发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-85" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-1-0" value="接发准备 每个人都要清楚做动作的目的性，不能盲目学习&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7639306481355832689"><mxGeometry x="1160" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-86" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-1" target="video-5-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-1-1" value="双打发接发 永远考虑对手出球最快的位置，慢的位置球真来了再说&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7501542236061420859"><mxGeometry x="1160" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-87" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-1" target="video-5-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-2" value="&lt;b&gt;发接发目的性&lt;/b&gt;&lt;br&gt;32 条 · 关键词：目的性、抓球、主动、限制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-88" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-2-0" value="打球要有目的性，更要清楚对手的目的性&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7300032085358660904"><mxGeometry x="1160" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-89" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-2" target="video-5-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-2-1" value="双打发球如何争取主动，就是规则高度内能拿多高拿多高，球能拿多前就拿多前😂&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7072543702161296640"><mxGeometry x="1160" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-90" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-2" target="video-5-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-6" value="&lt;b&gt;训练与纠错&lt;/b&gt;&lt;br&gt;157 条 · 训练设计、常见错误、实战复盘和恢复对抗能力。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1E4E8;strokeColor=#9A5968;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-91" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-6"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-0" value="&lt;b&gt;训练方法&lt;/b&gt;&lt;br&gt;58 条 · 关键词：训练、练习、多球、三步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-92" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-0-0" value="1 白鞋白胶布2低重心步法回动3低重心步法训练，这是我自创训练&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 25&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7085169366005714217"><mxGeometry x="1930" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-93" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-0" target="video-6-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-0-1" value="反手高远球 提供一个训练方法，方法不唯一&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 25&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7541623926234811705"><mxGeometry x="1930" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-94" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-0" target="video-6-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-1" value="&lt;b&gt;常见错误纠正&lt;/b&gt;&lt;br&gt;97 条 · 关键词：错误、不对、纠正、问题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-95" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-1-0" value="爆改球友 转髋还有问题，不过可以先熟悉动作了，其他的问题可以有了转髋后再微调&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 19&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7492357671853526329"><mxGeometry x="1930" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-96" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-1" target="video-6-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-1-1" value="挥拍方向 一定要让身边有这个问题的朋友看，根据长期线下培训的数据看，超过60%的球友有这样的问题&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 16&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7530102529830800699"><mxGeometry x="1930" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-97" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-1" target="video-6-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-2" value="&lt;b&gt;实战复盘&lt;/b&gt;&lt;br&gt;35 条 · 关键词：实战、战术、复盘、比赛" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-98" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-2-0" value="双打实战轮转 无论训练时有多么默契，实战中都会有配合失误，那实战看的就是两个人的容错够不够&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 22&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7614167503938610417"><mxGeometry x="1930" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-99" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-2" target="video-6-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-2-1" value="第一局双方都在摸索，失误都比较多，因为在引领节奏，所以我消耗更大，第二局都是多拍了，黄教练也在一直拆解我的…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7252154554828033295"><mxGeometry x="1930" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-100" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-2" target="video-6-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-6-3" value="&lt;b&gt;恢复与体能&lt;/b&gt;&lt;br&gt;4 条 · 关键词：恢复、体能、对抗能力、精疲力尽" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1990" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-101" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-6" target="subtopic-6-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-3-0" value="如何快速恢复对抗能力 觉得训练的时候实在不行了，就可以直接最后一个项目了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 28&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7432633273060314408"><mxGeometry x="1930" y="1986" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-102" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-3" target="video-6-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-6-3-1" value="职业运动员上网因为身体能力强，大部分采用跨步，但是依然每局还是能见到垫步的出现&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7099644893269839144"><mxGeometry x="1930" y="2064" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-103" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-6-3" target="video-6-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-7" value="&lt;b&gt;握拍与基本动作&lt;/b&gt;&lt;br&gt;117 条 · 握拍、基础挥拍、基础动作和拍面控制。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E4EDF0;strokeColor=#51727B;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="2370" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-104" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-7-0" value="&lt;b&gt;握拍&lt;/b&gt;&lt;br&gt;31 条 · 关键词：握拍、正手握拍、反手握拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-105" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-7" target="subtopic-7-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-0-0" value="半拳式握拍是发力必备的握拍，没有半拳式，基本出现不了鞭甩，因为大拇指会卡住&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 23&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7086276287681137961"><mxGeometry x="2700" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-106" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-0" target="video-7-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-0-1" value="握拍从准备握拍，向右旋转直至虎口对着正拍面，或接近正拍面&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7146762792438074665"><mxGeometry x="2700" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-107" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-0" target="video-7-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-7-1" value="&lt;b&gt;基础挥拍&lt;/b&gt;&lt;br&gt;34 条 · 关键词：基础挥拍、挥拍、随摆" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-108" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-7" target="subtopic-7-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-1-0" value="基础挥拍重快 由于要控制时长我剪辑的很精简，基础挥拍如何打的重，如何打的快，建议多看两边，详细的我们直播间…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 43&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7383154379915906319"><mxGeometry x="2700" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-109" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-1" target="video-7-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-1-1" value="基础挥拍 可以当网课看了，@ 你不会挥拍的小伙伴来看吧&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 29&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7453420876076240188"><mxGeometry x="2700" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-110" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-1" target="video-7-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-7-2" value="&lt;b&gt;拍面控制&lt;/b&gt;&lt;br&gt;72 条 · 关键词：拍面、角度、控制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-111" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-7" target="subtopic-7-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-2-0" value="反手动作不唯一，但是这种好上手，击球点在转过去的身前外侧&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 20&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7060717442825309480"><mxGeometry x="2700" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-112" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-2" target="video-7-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-7-2-1" value="握拍从准备握拍，向右旋转直至虎口对着正拍面，或接近正拍面&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 17&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7146762792438074665"><mxGeometry x="2700" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-113" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-7-2" target="video-7-2-1"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>