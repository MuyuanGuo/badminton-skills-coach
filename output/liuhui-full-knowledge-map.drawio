<mxfile host="app.diagrams.net" modified="2026-07-10T00:00:00.000Z" agent="Codex" version="24.7.17"><diagram id="liuhui-full" name="全量教学知识图谱"><mxGraphModel dx="2400" dy="2600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="2600" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="skill" value="刘辉羽毛球 Skill&lt;br&gt;&lt;b&gt;358 条教学证据&lt;/b&gt;&lt;br&gt;8 个主题大类 · 343 条已入主题索引" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#123B36;fontColor=#FFFFFF;strokeColor=#0C2B27;strokeWidth=3;fontSize=18;fontStyle=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1360" y="80" width="440" height="120" as="geometry" /></mxCell><mxCell id="category-0" value="&lt;b&gt;后场技术&lt;/b&gt;&lt;br&gt;211 条 · 后场击球、被动处理、杀吊突击与架拍框架。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEFEA;strokeColor=#176B5B;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-0" value="&lt;b&gt;被动后场与高远&lt;/b&gt;&lt;br&gt;77 条 · 关键词：被动、高远、后高点、底线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-0-0" value="反手被动高远 虽然被动，但是放松发力更重要，别说示范的球不到位，也打出界一米了，主要是在底线摄像机放不下了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7546109410041908538"><mxGeometry x="390" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-0" target="video-0-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-0-1" value="被动高远 别说这样容易抡大臂，不这样偷出来时间抢架拍位置也是个输，真被动就没时间侧身，没时间架拍，没空间做…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7558912953539071292"><mxGeometry x="390" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-0" target="video-0-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-1" value="&lt;b&gt;杀球、突击与压球&lt;/b&gt;&lt;br&gt;82 条 · 关键词：杀球、突击、压球、重杀" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-1-0" value="杀球瞄准 杀球瞄准 卢迦彧的杀球不是那种很重的，所以落点上就尤为重要，比赛中非常容易被防守反击!中间涉及到…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 26&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7659348110628345210"><mxGeometry x="390" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-1" target="video-0-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-1-1" value="不同杀球 给大家解释为什么每个运动员动作不一样，其实在我的视角里，都是脚蹬地开始发力传递到球拍，但是每个人…&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567155406117533051"><mxGeometry x="390" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-1" target="video-0-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-2" value="&lt;b&gt;架拍与框架&lt;/b&gt;&lt;br&gt;61 条 · 关键词：架拍、框架、抬拍、举拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-2-0" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 17&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="390" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-2" target="video-0-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-2-1" value="架拍的选择 在两个极端架拍的中间位置，就是最普通的架拍！没有绝对的对错，符合场景，符合自己的情况就是对！&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7658231159860261361"><mxGeometry x="390" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-2" target="video-0-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-3" value="&lt;b&gt;吊球与劈吊&lt;/b&gt;&lt;br&gt;19 条 · 关键词：吊球、劈吊、滑板、假动作" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-3-0" value="一定要看过上集再看下集啊朋友们&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7055130343476710667"><mxGeometry x="390" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-3" target="video-0-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-3-1" value="假动作可以不用，但是不能不会哦，要不拿什么耍帅😂，喜欢的留言直播间带走&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7061422431386324264"><mxGeometry x="390" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-3" target="video-0-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-4" value="&lt;b&gt;反手后场&lt;/b&gt;&lt;br&gt;65 条 · 关键词：反手、反拍、反手高远" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-14" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-4-0" value="因为击球点不同我们人的姿态不一样，所以动作和大臂的幅度必然不一样&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7296314453379910947"><mxGeometry x="390" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-4" target="video-0-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-4-1" value="反手高远 这个大臂啊，用的越精炼越好，越多越完蛋&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7535400692573211962"><mxGeometry x="390" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-16" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-4" target="video-0-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-1" value="&lt;b&gt;步法与移动&lt;/b&gt;&lt;br&gt;100 条 · 启动、移动、回动、低重心和不同区域步法。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7E6DE;strokeColor=#B85C38;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="830" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-17" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-0" value="&lt;b&gt;启动与预动&lt;/b&gt;&lt;br&gt;33 条 · 关键词：启动、预动、起动、蹬地" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-18" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-0-0" value="分解步法种类繁多，这是练启动有代表性的，一轮一口气做完，做3组。我肯定是没做到10秒钟，要不视频太长😓&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7056244399390412064"><mxGeometry x="1160" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-19" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-0" target="video-1-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-0-1" value="病毒感冒了，暂停直播，高烧不退&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7301508881325296931"><mxGeometry x="1160" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-20" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-0" target="video-1-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-1" value="&lt;b&gt;回动与连贯&lt;/b&gt;&lt;br&gt;30 条 · 关键词：回动、连贯、衔接、下一拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-21" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-1-0" value="杀球瞄准 杀球瞄准 卢迦彧的杀球不是那种很重的，所以落点上就尤为重要，比赛中非常容易被防守反击!中间涉及到…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 7&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7659348110628345210"><mxGeometry x="1160" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-22" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-1" target="video-1-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-1-1" value="被动也可以用这样的启动方式连接后交叉步&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 5&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7309303794733485327"><mxGeometry x="1160" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-1" target="video-1-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-2" value="&lt;b&gt;交叉步与并步&lt;/b&gt;&lt;br&gt;25 条 · 关键词：交叉步、并步、垫步、步伐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-24" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-2-0" value="终于有时间再更新步法了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7353467942706695458"><mxGeometry x="1160" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-2" target="video-1-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-2-1" value="今天偷懒，晚上见，发个没音乐的，纯粹目的杀上网就是交叉步，&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7065157571816000809"><mxGeometry x="1160" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-26" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-2" target="video-1-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-3" value="&lt;b&gt;低重心与被动救球&lt;/b&gt;&lt;br&gt;55 条 · 关键词：低重心、被动步法、救球、重心" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-27" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-3-0" value="1 白鞋白胶布2低重心步法回动3低重心步法训练，这是我自创训练&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 31&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7085169366005714217"><mxGeometry x="1160" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-28" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-3" target="video-1-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-3-1" value="女双比赛里基本都是这样杀，击球的瞬间要比脚落地早一点，“基本”同时&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7069575740836023587"><mxGeometry x="1160" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-29" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-3" target="video-1-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-4" value="&lt;b&gt;正手区与网前步法&lt;/b&gt;&lt;br&gt;20 条 · 关键词：正手区、网前步法、上网、前后步法" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-30" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-4-0" value="正手区前后步法（基础版） 正手区前后步法种类非常多，这是一种比较简单合理的步法，而且教学对象是左手，左右手…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567860375287303035"><mxGeometry x="1160" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-31" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-4" target="video-1-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-4-1" value="也不要问为什么不放网，对方远网球这个不可能去钓鱼失误率太高，也不能挡远网，惯性大没办法抓推&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7092959332047785250"><mxGeometry x="1160" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-32" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-4" target="video-1-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-2" value="&lt;b&gt;发力与身体运用&lt;/b&gt;&lt;br&gt;224 条 · 放松发力、旋转传导、腰腹、手腕与击球发力区间。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7EDF5;strokeColor=#456A8A;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-33" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-0" value="&lt;b&gt;放松与爆发&lt;/b&gt;&lt;br&gt;144 条 · 关键词：放松、爆发、发力、打透" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-34" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-0-0" value="放松架拍 没有说对错，是很多人还不会自然传动力量就开始锁定身体，锁住力量是为了让会发力的人爆发力最大化，不…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 21&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7628342769941691121"><mxGeometry x="1930" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-35" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-0" target="video-2-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-0-1" value="手指是末梢的发力，前面还需要很多带动，食指拇指都需要发力，只不过是支撑&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7097047150479084835"><mxGeometry x="1930" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-36" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-0" target="video-2-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-1" value="&lt;b&gt;腰腹与身体旋转&lt;/b&gt;&lt;br&gt;78 条 · 关键词：腰腹、核心、旋转、转体" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-37" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-1-0" value="腰腹发力 手放好位置，感受腰腹发力的方向，只有把方向做对，击球才能有效果&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 14&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7494729488699559225"><mxGeometry x="1930" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-38" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-1" target="video-2-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-1-1" value="花两分多钟把视频看完，让朋友们不在徘徊&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7125615679402724623"><mxGeometry x="1930" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-39" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-1" target="video-2-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-2" value="&lt;b&gt;手腕、内旋与拍面&lt;/b&gt;&lt;br&gt;111 条 · 关键词：手腕、内旋、拍面、握拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-40" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-2-0" value="半拳式握拍是发力必备的握拍，没有半拳式，基本出现不了鞭甩，因为大拇指会卡住&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7086276287681137961"><mxGeometry x="1930" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-41" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-2" target="video-2-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-2-1" value="多体系应用 标准的普通体系就是力量由下向上自然传递，没有哪个环节着重发力&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7622167629645727717"><mxGeometry x="1930" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-42" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-2" target="video-2-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-3" value="&lt;b&gt;贴球发力&lt;/b&gt;&lt;br&gt;12 条 · 关键词：贴球、贴近、发力空间" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-43" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-3-0" value="兄弟们也可以看往期的手指发力，贴球发力来做铺垫&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7145708380047297833"><mxGeometry x="1930" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-44" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-3" target="video-2-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-3-1" value="压球新讲 就算追求贴球发力，也得是建立在能把动作做完的基础上贴，怕打不到球也会本能的把球拍接近球而失去发力…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7440406891664133428"><mxGeometry x="1930" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-3" target="video-2-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-4" value="&lt;b&gt;挥拍路径&lt;/b&gt;&lt;br&gt;72 条 · 关键词：挥拍、随挥、半程、全程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-46" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-4-0" value="后场发力 给大家解释一下，这些部位发力分别如何表现，帮助大家学习&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 13&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7536519262631611707"><mxGeometry x="1930" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-47" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-4" target="video-2-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-4-1" value="基础挥拍重快 由于要控制时长我剪辑的很精简，基础挥拍如何打的重，如何打的快，建议多看两边，详细的我们直播间…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7383154379915906319"><mxGeometry x="1930" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-48" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-4" target="video-2-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-3" value="&lt;b&gt;中前场与抽挡&lt;/b&gt;&lt;br&gt;105 条 · 抽挡、接杀、防守、网前技术和中前场转换。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBCF;strokeColor=#967326;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="2370" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-49" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-0" value="&lt;b&gt;平抽挡与高速对抗&lt;/b&gt;&lt;br&gt;9 条 · 关键词：抽挡、平抽挡、高速对抗、快球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-50" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-0-0" value="握拍微调 抽挡反手为主，尽量不做正反手转换&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7447084061371272507"><mxGeometry x="2700" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-51" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-0" target="video-3-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-0-1" value="高速对抗步法 小姐姐是两省冠军🏆，这种情况属于高速对抗状态下，就是球都比较平，没有侧身的时间和意义&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7652440366436945017"><mxGeometry x="2700" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-52" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-0" target="video-3-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-1" value="&lt;b&gt;接杀与防守&lt;/b&gt;&lt;br&gt;41 条 · 关键词：接杀、防守、防反、挡杀" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-53" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-1-0" value="双打防守思路 你总会遇到你挑不起来的进攻&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 13&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7621243051541587889"><mxGeometry x="2700" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-54" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-1" target="video-3-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-1-1" value="双打一般情况下的防守上集，手指破了，挥速慢，望谅解&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7054025391601650948"><mxGeometry x="2700" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-55" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-1" target="video-3-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-2" value="&lt;b&gt;网前搓勾扑&lt;/b&gt;&lt;br&gt;50 条 · 关键词：网前、搓球、勾球、扑球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-56" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-2-0" value="身前位勾球，和侧身位的勾球不一样，正手也存在变拍，只不过没反手那么需要&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 14&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7064010057020673314"><mxGeometry x="2700" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-57" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-2" target="video-3-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-2-1" value="不是说勾球不能带过去，是不能大臂和球拍一起过去，如果学不会，就先练简单的勾球，这属于进阶&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7231373527314631947"><mxGeometry x="2700" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-58" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-2" target="video-3-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-3" value="&lt;b&gt;挡网与放网&lt;/b&gt;&lt;br&gt;14 条 · 关键词：挡网、放网、网前球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-59" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-3-0" value="中腰球出来，出现轮转的可能性很大&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 7&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7106697344128748835"><mxGeometry x="2700" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-60" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-3" target="video-3-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-3-1" value="别练了今天，研究研究战术吧&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7080735688819281193"><mxGeometry x="2700" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-61" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-3" target="video-3-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-4" value="&lt;b&gt;中前场衔接&lt;/b&gt;&lt;br&gt;18 条 · 关键词：中前场、衔接、连贯、封网" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-62" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-4-0" value="被动也可以用这样的启动方式连接后交叉步&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 5&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7309303794733485327"><mxGeometry x="2700" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-63" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-4" target="video-3-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-4-1" value="别练了今天，研究研究战术吧&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7080735688819281193"><mxGeometry x="2700" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-64" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-4" target="video-3-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-4" value="&lt;b&gt;双打战术&lt;/b&gt;&lt;br&gt;59 条 · 双打轮转、防守站位、封网、进攻组织和发接发配合。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9E3F2;strokeColor=#72578C;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-65" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-0" value="&lt;b&gt;双打发接发&lt;/b&gt;&lt;br&gt;11 条 · 关键词：双打发接发、接发、发接发、抓球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-66" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-0-0" value="双打发接发 永远考虑对手出球最快的位置，慢的位置球真来了再说&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7501542236061420859"><mxGeometry x="390" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-67" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-0" target="video-4-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-0-1" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="390" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-68" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-0" target="video-4-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-1" value="&lt;b&gt;轮转与补位&lt;/b&gt;&lt;br&gt;15 条 · 关键词：轮转、补位、前后、左右" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-69" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-1-0" value="双打实战轮转 无论训练时有多么默契，实战中都会有配合失误，那实战看的就是两个人的容错够不够&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 8&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7614167503938610417"><mxGeometry x="390" y="1656"