h="300" height="82" as="geometry" /></mxCell><mxCell id="edge-144" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-8" target="subtopic-8-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-8-3-0" value="单打防守反击&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7602766054809333617"><mxGeometry x="390" y="3026" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-145" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-8-3" target="video-8-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-8-3-1" value="吊球和刹球要相互配合使用，拉扯对手防守的站位，一味的强攻很容易被防反&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7115241358255803683"><mxGeometry x="390" y="3104" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-146" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-8-3" target="video-8-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-8-4" value="&lt;b&gt;单打综合待细分&lt;/b&gt;&lt;br&gt;7 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="3195" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-147" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-8" target="subtopic-8-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-8-4-0" value="减少失误 一个球总失误，除了动作不熟练，还有可能是人的节奏和球速不匹配，因为节奏陌生而产生的失误&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7630800123594285305"><mxGeometry x="390" y="3191" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-148" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-8-4" target="video-8-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-8-4-1" value="单打技术 借用一下三位健将和我昔日对抗的素材，感谢&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7376838935164505384"><mxGeometry x="390" y="3269" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-149" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-8-4" target="video-8-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-9" value="&lt;b&gt;装备选择&lt;/b&gt;&lt;br&gt;37 条 · 与动作能力直接相关的球拍、球线和参数选择，不包含商品推广。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7E6DE;strokeColor=#B85C38;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="830" y="2400" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-150" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-9"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-9-0" value="&lt;b&gt;球拍选择与重量&lt;/b&gt;&lt;br&gt;37 条 · 关键词：选择球拍、球拍重量、重量球拍、拍重" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="2535" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-151" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-9" target="subtopic-9-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-9-0-0" value="动作比较 大家需要根据能力选择球拍，而不同的重量的球拍，从动作的体现上会有区别，但是动作的本质都是一样的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 31&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7486058135547891004"><mxGeometry x="1160" y="2531" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-152" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-9-0" target="video-9-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-9-0-1" value="基础挥拍重快 由于要控制时长我剪辑的很精简，基础挥拍如何打的重，如何打的快，建议多看两边，详细的我们直播间…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7383154379915906319"><mxGeometry x="1160" y="2609" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-153" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-9-0" target="video-9-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-9-1" value="&lt;b&gt;球线与磅数&lt;/b&gt;&lt;br&gt;0 条 · 关键词：球线、拍线、磅数、线床" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="2700" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-154" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-9" target="subtopic-9-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-9-2" value="&lt;b&gt;装备选择综合待细分&lt;/b&gt;&lt;br&gt;0 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="2865" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-155" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-9" target="subtopic-9-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-10" value="&lt;b&gt;训练与纠错&lt;/b&gt;&lt;br&gt;59 条 · 训练设计、动作纠错、实战复盘、恢复与体能。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7EDF5;strokeColor=#456A8A;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="2400" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-156" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-10"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-10-0" value="&lt;b&gt;专项训练方法&lt;/b&gt;&lt;br&gt;2 条 · 关键词：多球训练、训练方法、练习方法、分解练习" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="2535" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-157" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-10" target="subtopic-10-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-0-0" value="反手高远球 提供一个训练方法，方法不唯一&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7541623926234811705"><mxGeometry x="1930" y="2531" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-158" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-0" target="video-10-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-0-1" value="训练方法由我的师弟 提供，亲测真实有效&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7236568825607621922"><mxGeometry x="1930" y="2609" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-159" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-0" target="video-10-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-10-1" value="&lt;b&gt;常见错误纠正&lt;/b&gt;&lt;br&gt;2 条 · 关键词：常见错误、纠正、错误动作、改正" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="2700" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-160" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-10" target="subtopic-10-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-1-0" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="1930" y="2696" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-161" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-1" target="video-10-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-1-1" value="辅助手的作用（1）&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7597528312752490929"><mxGeometry x="1930" y="2774" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-162" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-1" target="video-10-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-10-2" value="&lt;b&gt;实战复盘&lt;/b&gt;&lt;br&gt;1 条 · 关键词：实战复盘、比赛复盘、实战分析、课堂随录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="2865" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-163" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-10" target="subtopic-10-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-2-0" value="课堂随录的，比平时唠叨些，需要的朋友自取&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7271452082337598760"><mxGeometry x="1930" y="2861" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-164" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-2" target="video-10-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-10-3" value="&lt;b&gt;恢复与体能&lt;/b&gt;&lt;br&gt;2 条 · 关键词：恢复对抗、体能、精疲力尽、恢复训练" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="3030" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-165" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-10" target="subtopic-10-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-3-0" value="如何快速恢复对抗能力 觉得训练的时候实在不行了，就可以直接最后一个项目了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7432633273060314408"><mxGeometry x="1930" y="3026" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-166" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-3" target="video-10-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-3-1" value="职业运动员上网因为身体能力强，大部分采用跨步，但是依然每局还是能见到垫步的出现&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7099644893269839144"><mxGeometry x="1930" y="3104" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-167" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-3" target="video-10-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-10-4" value="&lt;b&gt;教学与训练综合待细分&lt;/b&gt;&lt;br&gt;52 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="3195" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-168" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-10" target="subtopic-10-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-4-0" value="假动作可以不用，但是不能不会哦，要不拿什么耍帅😂，喜欢的留言直播间带走&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7061422431386324264"><mxGeometry x="1930" y="3191" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-169" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-4" target="video-10-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-10-4-1" value="其实羽毛球技术就在我们生活中，换一种学习方式也是不错的选择&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7091101085535915279"><mxGeometry x="1930" y="3269" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-170" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-10-4" target="video-10-4-1"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>