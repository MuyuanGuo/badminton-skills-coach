<mxfile host="app.diagrams.net" modified="2026-07-10T00:00:00.000Z" agent="Codex" version="24.7.17"><diagram id="liuhui-full" name="全量教学知识图谱"><mxGraphModel dx="2400" dy="2600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="2600" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="skill" value="刘辉羽毛球 Skill&lt;br&gt;&lt;b&gt;352 条教学证据&lt;/b&gt;&lt;br&gt;11 个主题大类 · 352 条已入主题索引" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#123B36;fontColor=#FFFFFF;strokeColor=#0C2B27;strokeWidth=3;fontSize=18;fontStyle=1;arcSize=8;" vertex="1" parent="1"><mxGeometry x="1360" y="80" width="440" height="120" as="geometry" /></mxCell><mxCell id="category-0" value="&lt;b&gt;后场技术&lt;/b&gt;&lt;br&gt;87 条 · 后场击球、被动处理、杀吊突击与架拍框架。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEFEA;strokeColor=#176B5B;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-0" value="&lt;b&gt;被动后场与高远&lt;/b&gt;&lt;br&gt;22 条 · 关键词：被动后场、反手高远、后高点、摆脱" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-0-0" value="反手被动高远 虽然被动，但是放松发力更重要，别说示范的球不到位，也打出界一米了，主要是在底线摄像机放不下了&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 27&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7546109410041908538"><mxGeometry x="390" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-0" target="video-0-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-0-1" value="反手高远 这个大臂啊，用的越精炼越好，越多越完蛋&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 24&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7535400692573211962"><mxGeometry x="390" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-0" target="video-0-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-1" value="&lt;b&gt;杀球、突击与压球&lt;/b&gt;&lt;br&gt;26 条 · 关键词：杀球、重杀、点杀、突击" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-1-0" value="杀球瞄准 杀球瞄准 卢迦彧的杀球不是那种很重的，所以落点上就尤为重要，比赛中非常容易被防守反击!中间涉及到…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 44&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7659348110628345210"><mxGeometry x="390" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-1" target="video-0-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-1-1" value="不同杀球 给大家解释为什么每个运动员动作不一样，其实在我的视角里，都是脚蹬地开始发力传递到球拍，但是每个人…&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567155406117533051"><mxGeometry x="390" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-1" target="video-0-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-2" value="&lt;b&gt;架拍与后场框架&lt;/b&gt;&lt;br&gt;39 条 · 关键词：架拍、顶肘、引拍、抬拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-2-0" value="后场框架应用 如果基础好，可以推荐出快速框架，之前发过很多爆发力出框架的作品！但是顶肘动作小带来效率的同时…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 58&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7589749293205363633"><mxGeometry x="390" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-2" target="video-0-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-2-1" value="被动高远 别说这样容易抡大臂，不这样偷出来时间抢架拍位置也是个输，真被动就没时间侧身，没时间架拍，没空间做…&lt;br&gt;&lt;font color='#52625E'&gt;curated · score 33&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7558912953539071292"><mxGeometry x="390" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-2" target="video-0-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-3" value="&lt;b&gt;吊球与劈吊&lt;/b&gt;&lt;br&gt;6 条 · 关键词：吊球、劈吊、滑板、软压" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-3-0" value="软压还包括点杀，远网吊球等等&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 16&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7093706918492917033"><mxGeometry x="390" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-3" target="video-0-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-3-1" value="吊球和刹球要相互配合使用，拉扯对手防守的站位，一味的强攻很容易被防反&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7115241358255803683"><mxGeometry x="390" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-3" target="video-0-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-4" value="&lt;b&gt;反手后场&lt;/b&gt;&lt;br&gt;11 条 · 关键词：反手高远、反手后场、反手过渡、反手杀球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-14" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-4-0" value="反手高远 这个大臂啊，用的越精炼越好，越多越完蛋&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7535400692573211962"><mxGeometry x="390" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-4" target="video-0-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-4-1" value="反手杀球 不同的击球位置也会使用不同的动作,都有不同的效果&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7550305145877155131"><mxGeometry x="390" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-16" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-4" target="video-0-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-0-5" value="&lt;b&gt;后场综合待细分&lt;/b&gt;&lt;br&gt;3 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1280" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-17" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-0" target="subtopic-0-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-5-0" value="做两期前后场一致性的视频，你们知道用的都是那种技术嘛？后面有入门讲解，教学后期出，或者直播的时候讲吧，东西…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7054395778814561575"><mxGeometry x="390" y="1276" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-18" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-5" target="video-0-5-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-0-5-1" value="被人教学鞭打发力 受益匪浅&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7418417650264558848"><mxGeometry x="390" y="1354" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-19" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-0-5" target="video-0-5-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-1" value="&lt;b&gt;网前技术&lt;/b&gt;&lt;br&gt;49 条 · 搓、勾、推、扑、放网及网前持拍框架。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7E6DE;strokeColor=#B85C38;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="830" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-20" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-0" value="&lt;b&gt;搓球与滚网&lt;/b&gt;&lt;br&gt;10 条 · 关键词：搓球、滚网、平搓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-21" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-0-0" value="滚网搓球 双打网前有人看守时有奇效&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 23&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7509355373729762619"><mxGeometry x="1160" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-22" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-0" target="video-1-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-0-1" value="平搓远网 平搓可以根据情况加力减力，手臂也可以适当的介入辅助&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 22&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7411850466457292084"><mxGeometry x="1160" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-0" target="video-1-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-1" value="&lt;b&gt;勾球与变线&lt;/b&gt;&lt;br&gt;12 条 · 关键词：勾球、勾对角、网前变线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-24" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-1-0" value="身前位勾球，和侧身位的勾球不一样，正手也存在变拍，只不过没反手那么需要&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 24&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7064010057020673314"><mxGeometry x="1160" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-1" target="video-1-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-1-1" value="不是说勾球不能带过去，是不能大臂和球拍一起过去，如果学不会，就先练简单的勾球，这属于进阶&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 23&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7231373527314631947"><mxGeometry x="1160" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-26" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-1" target="video-1-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-2" value="&lt;b&gt;扑球与推球&lt;/b&gt;&lt;br&gt;12 条 · 关键词：扑球、推球、抢网" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-27" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-2-0" value="摇摆球对付抢网凶狠的对手，如果对方不抢网就没什么用啦😂&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7095554075210550528"><mxGeometry x="1160" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-28" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-2" target="video-1-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-2-1" value="模拟的防守挡斜线随后抢网反击&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7127470220309957923"><mxGeometry x="1160" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-29" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-2" target="video-1-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-3" value="&lt;b&gt;放网与挡网&lt;/b&gt;&lt;br&gt;7 条 · 关键词：放网、挡网、网前球" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-30" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-3-0" value="挡网 我最近发的东西都是大家认为简单，但是一点不简单的东西&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 13&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7524557392328461627"><mxGeometry x="1160" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-31" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-3" target="video-1-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-3-1" value="用的双打平搓技术，这不是花活了吧？谁说我双打放网教学里是蒙的来着？😂&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7071800926553541922"><mxGeometry x="1160" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-32" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-3" target="video-1-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-4" value="&lt;b&gt;网前框架与步法&lt;/b&gt;&lt;br&gt;8 条 · 关键词：网前框架、网前步法、上网、持拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-33" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-4-0" value="今天偷懒，晚上见，发个没音乐的，纯粹目的杀上网就是交叉步，&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7065157571816000809"><mxGeometry x="1160" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-34" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-4" target="video-1-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-4-1" value="s上网小飞侠“两步一冲”，曹植当年要有这样的七步早就蹬出皇宫了！&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7142313105324870950"><mxGeometry x="1160" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-35" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-4" target="video-1-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-1-5" value="&lt;b&gt;网前综合待细分&lt;/b&gt;&lt;br&gt;5 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1280" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-36" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-1" target="subtopic-1-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-5-0" value="双打网前意识 双打只要能让球往下飞，对面回球就是往上飞的，不一定要打硬，打软点对面更难借力&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7504391919716273468"><mxGeometry x="1160" y="1276" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-37" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-5" target="video-1-5-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-1-5-1" value="总之球必须向我们飞来才有练的价值。不需要网，网前练的就是控球感，练自由使用技术，有面墙就行&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7078487171803467042"><mxGeometry x="1160" y="1354" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-38" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-1-5" target="video-1-5-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-2" value="&lt;b&gt;中前场与抽挡&lt;/b&gt;&lt;br&gt;20 条 · 平抽挡、接杀、防反及中前场高速衔接。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7EDF5;strokeColor=#456A8A;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="1600" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-39" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-0" value="&lt;b&gt;平抽挡与高速对抗&lt;/b&gt;&lt;br&gt;5 条 · 关键词：平抽挡、抽挡、压抽、快挡" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-40" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-0-0" value="握拍微调 抽挡反手为主，尽量不做正反手转换&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7447084061371272507"><mxGeometry x="1930" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-41" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-0" target="video-2-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-0-1" value="高速对抗步法 小姐姐是两省冠军🏆，这种情况属于高速对抗状态下，就是球都比较平，没有侧身的时间和意义&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7652440366436945017"><mxGeometry x="1930" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-42" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-0" target="video-2-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-1" value="&lt;b&gt;接杀与防反&lt;/b&gt;&lt;br&gt;12 条 · 关键词：接杀、挡杀、防反、防守反击" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-43" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-1-0" value="打羽毛球最爽的就是杀球和接杀&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7090377448017235234"><mxGeometry x="1930" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-44" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-1" target="video-2-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-1-1" value="单打防守反击&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 10&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7602766054809333617"><mxGeometry x="1930" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-1" target="video-2-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-2" value="&lt;b&gt;中前场衔接&lt;/b&gt;&lt;br&gt;2 条 · 关键词：中前场、封网、抢点、抽压" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-46" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-2-0" value="压迫位封网 祝大家新年快乐！大年初二也不要忘记研究羽毛球啊！&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7607852875611759802"><mxGeometry x="1930" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-47" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-2" target="video-2-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-2-1" value="这种情况下是对方防守的好，过来的平，防远网转推的方法，如果有机会，还是越快抢点越高更好&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7258462271670586658"><mxGeometry x="1930" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-48" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-2" target="video-2-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-2-3" value="&lt;b&gt;中前场综合待细分&lt;/b&gt;&lt;br&gt;1 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="1600" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-49" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-2" target="subtopic-2-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-2-3-0" value="步法节奏 越着急跑输的越快，中场待着不动也不行，所以只能去找到这个接球的节奏&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7571574635323124145"><mxGeometry x="1930" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-50" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-2-3" target="video-2-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-3" value="&lt;b&gt;步法与移动&lt;/b&gt;&lt;br&gt;40 条 · 启动、回动、不同步型、重心与场区移动。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBCF;strokeColor=#967326;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="2370" y="320" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-51" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-0" value="&lt;b&gt;启动与预动&lt;/b&gt;&lt;br&gt;13 条 · 关键词：启动、预动、起动、第一步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="455" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-52" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-0-0" value="分解步法种类繁多，这是练启动有代表性的，一轮一口气做完，做3组。我肯定是没做到10秒钟，要不视频太长😓&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7056244399390412064"><mxGeometry x="2700" y="451" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-53" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-0" target="video-3-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-0-1" value="被动也可以用这样的启动方式连接后交叉步&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7309303794733485327"><mxGeometry x="2700" y="529" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-54" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-0" target="video-3-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-1" value="&lt;b&gt;回动与下一拍&lt;/b&gt;&lt;br&gt;17 条 · 关键词：回动、回位、还原、下一拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="620" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-55" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-1-0" value="这属于为了下一拍更好衔接的步法，也是使用率最高的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 20&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7229889111706848544"><mxGeometry x="2700" y="616" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-56" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-1" target="video-3-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-1-1" value="并不是说一定要一步回位。而是体现向左回动，左脚的重要性&lt;br&gt;&lt;font color='#52625E'&gt;reviewed_transcript · score 19&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7059589039694957864"><mxGeometry x="2700" y="694" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-57" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-1" target="video-3-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-2" value="&lt;b&gt;交叉步、并步与垫步&lt;/b&gt;&lt;br&gt;10 条 · 关键词：交叉步、并步、垫步、马来步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="785" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-58" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-2-0" value="发个老库存，垫步和并步都接双脚起跳的合适步法&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 12&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7064753436809514281"><mxGeometry x="2700" y="781" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-59" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-2" target="video-3-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-2-1" value="今天偷懒，晚上见，发个没音乐的，纯粹目的杀上网就是交叉步，&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7065157571816000809"><mxGeometry x="2700" y="859" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-60" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-2" target="video-3-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-3" value="&lt;b&gt;低重心与被动救球&lt;/b&gt;&lt;br&gt;3 条 · 关键词：低重心、被动步法、救球、跑动不到位" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="950" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-61" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-3-0" value="1 白鞋白胶布2低重心步法回动3低重心步法训练，这是我自创训练&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 29&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7085169366005714217"><mxGeometry x="2700" y="946" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-62" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-3" target="video-3-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-3-1" value="后场就是刻意练的被动步法，不是不积极，主要练回动的节奏感&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7280727710740139264"><mxGeometry x="2700" y="1024" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-63" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-3" target="video-3-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-4" value="&lt;b&gt;场区移动&lt;/b&gt;&lt;br&gt;2 条 · 关键词：前后步法、网前步法、后场步法、正手区步法" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1115" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-64" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-4-0" value="正手区前后步法（基础版） 正手区前后步法种类非常多，这是一种比较简单合理的步法，而且教学对象是左手，左右手…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7567860375287303035"><mxGeometry x="2700" y="1111" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-65" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-4" target="video-3-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-4-1" value="正手网前步法 当然还要注意左手的摆放和重心的控制，但是时间有限，直播的时候讲吧&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7406541084219821312"><mxGeometry x="2700" y="1189" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-66" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-4" target="video-3-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-3-5" value="&lt;b&gt;步法综合待细分&lt;/b&gt;&lt;br&gt;6 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="2370" y="1280" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-67" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-3" target="subtopic-3-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-5-0" value="挂臂三招，由我腿伤时所创，专门用于步法慢的或者懒得动的人，属于绝活技能，绝对不伤腕，想学哪个？还有我是正经…&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7167546787073477900"><mxGeometry x="2700" y="1276" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-68" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-5" target="video-3-5-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-3-5-1" value="保护身位，信息不明朗少打斜线，无视错别字，视频拿到的时候就是这样的&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7304104136306412835"><mxGeometry x="2700" y="1354" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-69" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-3-5" target="video-3-5-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-4" value="&lt;b&gt;发力与身体运用&lt;/b&gt;&lt;br&gt;130 条 · 放松传导、身体旋转、内外旋、击球空间与挥拍路径。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9E3F2;strokeColor=#72578C;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="60" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-70" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-0" value="&lt;b&gt;放松、传导与爆发&lt;/b&gt;&lt;br&gt;12 条 · 关键词：放松发力、力量传导、爆发、打透" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-71" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-0-0" value="腰腹的使用是小而快的爆发力，不要转的太狠太大&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 11&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7084422988291935523"><mxGeometry x="390" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-72" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-0" target="video-4-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-0-1" value="放松发力 真挑出来的底线球，不放松做力传导杀是不行的，现在没人愿意学这些了&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7552759261840952636"><mxGeometry x="390" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-73" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-0" target="video-4-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-1" value="&lt;b&gt;腰腹、核心与转体&lt;/b&gt;&lt;br&gt;20 条 · 关键词：腰腹、核心、转体、转髋" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-74" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-1-0" value="腰腹发力 手放好位置，感受腰腹发力的方向，只有把方向做对，击球才能有效果&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 21&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7494729488699559225"><mxGeometry x="390" y="1656" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-75" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-1" target="video-4-1-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-1-1" value="爆改球友 转髋还有问题，不过可以先熟悉动作了，其他的问题可以有了转髋后再微调&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7492357671853526329"><mxGeometry x="390" y="1734" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-76" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-1" target="video-4-1-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-2" value="&lt;b&gt;小臂旋转与手腕&lt;/b&gt;&lt;br&gt;45 条 · 关键词：内旋、外旋、小臂旋转、手腕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-77" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-2-0" value="00:00 / 00:47 后场发力下集，由下到上一步一步带动全身协调发力，发力为外旋，不会伤手腕，伤手腕…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 24&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7052600326116887812"><mxGeometry x="390" y="1821" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-78" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-2" target="video-4-2-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-2-1" value="发力细节 每个人的情况不一样，我告诉抡大臂的人要用小臂，告诉内旋挥不正的人压手腕，不过他 但凡能做对一点，…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 22&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7570301879545426171"><mxGeometry x="390" y="1899" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-79" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-2" target="video-4-2-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-3" value="&lt;b&gt;击球空间与发力点&lt;/b&gt;&lt;br&gt;27 条 · 关键词：贴球、发力空间、击球点、高点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="1990" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-80" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-3-0" value="注意击球点要在起跳的高点击，而不是向上的过程中，45度起跳是更容易的起跳杀球，视频中的侧身跳杀对身体要求更…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7055491154288102667"><mxGeometry x="390" y="1986" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-81" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-3" target="video-4-3-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-3-1" value="压球新讲 就算追求贴球发力，也得是建立在能把动作做完的基础上贴，怕打不到球也会本能的把球拍接近球而失去发力…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 15&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7440406891664133428"><mxGeometry x="390" y="2064" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-82" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-3" target="video-4-3-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-4" value="&lt;b&gt;挥拍路径&lt;/b&gt;&lt;br&gt;42 条 · 关键词：挥拍路径、基础挥拍、随挥、随摆" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="2155" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-83" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-4"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-4-0" value="不用管身高，网带能卡住大臂就行在哪卡都可以，用网带辅助不依赖大臂挥下去&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 27&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7322291358931127592"><mxGeometry x="390" y="2151" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-84" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-4" target="video-4-4-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-4-1" value="基础挥拍重快 由于要控制时长我剪辑的很精简，基础挥拍如何打的重，如何打的快，建议多看两边，详细的我们直播间…&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 27&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7383154379915906319"><mxGeometry x="390" y="2229" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-85" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-4" target="video-4-4-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-4-5" value="&lt;b&gt;发力综合待细分&lt;/b&gt;&lt;br&gt;10 条 · 关键词：" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="60" y="2320" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-86" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-4" target="subtopic-4-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-5-0" value="双打一般情况下的防守上集，手指破了，挥速慢，望谅解&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7054025391601650948"><mxGeometry x="390" y="2316" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-87" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-5" target="video-4-5-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-4-5-1" value="反手跳sha 这是给已经会反手发力的朋友学习的，不会的也可以先收藏&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7499776424493075772"><mxGeometry x="390" y="2394" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-88" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-4-5" target="video-4-5-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="category-5" value="&lt;b&gt;握拍与拍面&lt;/b&gt;&lt;br&gt;30 条 · 正反手握拍、握拍转换、手指发力和拍面控制。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2ECE4;strokeColor=#4F7A43;strokeWidth=2;fontSize=15;fontStyle=1;arcSize=6;" vertex="1" parent="1"><mxGeometry x="830" y="1360" width="620" height="86" as="geometry" /></mxCell><mxCell id="edge-89" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="skill" target="category-5"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-0" value="&lt;b&gt;正手握拍&lt;/b&gt;&lt;br&gt;8 条 · 关键词：正手握拍、半拳式、虎口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1495" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-90" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-0-0" value="半拳式握拍是发力必备的握拍，没有半拳式，基本出现不了鞭甩，因为大拇指会卡住&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 18&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7086276287681137961"><mxGeometry x="1160" y="1491" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-91" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-0" target="video-5-0-0"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-0-1" value="握拍从准备握拍，向右旋转直至虎口对着正拍面，或接近正拍面&lt;br&gt;&lt;font color='#52625E'&gt;medium · score 9&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FBFA;strokeColor=#CBD6D2;strokeWidth=1;fontSize=11;align=left;spacingLeft=8;arcSize=5;" vertex="1" parent="1" link="https://www.douyin.com/video/7146762792438074665"><mxGeometry x="1160" y="1569" width="290" height="68" as="geometry" /></mxCell><mxCell id="edge-92" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="subtopic-5-0" target="video-5-0-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-1" value="&lt;b&gt;反手握拍&lt;/b&gt;&lt;br&gt;0 条 · 关键词：反手握拍、拇指握拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1660" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-93" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="subtopic-5-2" value="&lt;b&gt;握拍转换与微调&lt;/b&gt;&lt;br&gt;5 条 · 关键词：握拍转换、变拍、握拍微调、灵活握拍" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#AAB8B4;strokeWidth=1.5;fontSize=12;align=left;spacingLeft=10;arcSize=5;" vertex="1" parent="1"><mxGeometry x="830" y="1825" width="300" height="82" as="geometry" /></mxCell><mxCell id="edge-94" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7A8A86;strokeWidth=2;" edge="1" parent="1" source="category-5" target="subtopic-5-2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="video-5-2-0" value="握拍微调 抽挡反手为主，尽量不做正反手转换&lt;br&gt;&lt;font color='#52625E'&gt;visual_reviewed · score 9&lt;/font&g